# Copie para .env e preencha com os valores do painel Supabase (Settings → API).
# Não commite o arquivo .env.

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key_here"

